    "# Convert fractions to decimals\n",
    "def fraction_to_float(fraction_str):\n",
    "    try:\n",
    "        return float(Fraction(fraction_str))\n",
    "    except (ValueError, TypeError):\n",
    "        return fraction_str\n",
    "    \n",
    "rt_reviews_df['rating'] = rt_reviews_df['rating'].apply(fraction_to_float)\n",
    "rt_reviews_df"
